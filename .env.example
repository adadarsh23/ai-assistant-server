# =========================
# GENERAL
# =========================
PORT=5000
NODE_ENV=production

# =========================
# FRONTEND
# =========================
FRONTEND_URL=http://localhost:5173   # Your React/Vite frontend URL

# =========================
# GOOGLE GEMINI API
# =========================
VITE_GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash       # Optional: default is gemini-2.0-flash
SERVER_API_TOKEN=                   # Optional: protect /api/* with this bearer token
RENDER_SERVICE_ID=                  # Optional: Render service id
RENDER_OUTBOUND_IPS=                # Optional: comma-separated outbound CIDRs

# =========================
# DATABASE (Optional)
# =========================
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/gemini?retryWrites=true&w=majority
